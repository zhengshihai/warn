<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tianhai.warn.mapper.SystemLogMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.tianhai.warn.model.SystemLog">
        <id column="id" property="id"/>
        <result column="log_id" property="logId"/>
        <result column="user_no" property="userNo"/>
        <result column="username" property="username"/>
        <result column="user_role" property="userRole"/>
        <result column="operation" property="operation"/>
        <result column="method" property="method"/>
        <result column="params" property="params"/>
        <result column="ip" property="ip"/>
        <result column="status" property="status"/>
        <result column="error_msg" property="errorMsg"/>
        <result column="create_time" property="createTime"/>
    </resultMap>
    
    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, log_id, user_no, username, user_role, operation, method, params, ip, status, error_msg, create_time
    </sql>
    
    <!-- 根据ID查询 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM system_log
        WHERE id = #{id}
    </select>
    
    <!-- 查询所有 -->
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM system_log
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据条件查询 -->
    <select id="selectByCondition" resultMap="BaseResultMap" parameterType="com.tianhai.warn.query.SystemLogQuery">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM system_log
        <where>
            <!-- 精确匹配字段 -->
            <if test="id != null">
                AND id = #{id}
            </if>
            <if test="logId != null and logId != ''">
                AND log_id = #{logId}
            </if>
            <if test="userNo != null and userNo != ''">
                AND user_no = #{userNo}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="userRole != null and userRole != ''">
                AND user_role = #{userRole}
            </if>
            
            <!-- 模糊匹配字段 -->
            <if test="usernameLike != null and usernameLike != ''">
                AND username LIKE CONCAT('%', #{usernameLike}, '%')
            </if>
            <if test="operationLike != null and operationLike != ''">
                AND operation LIKE CONCAT('%', #{operationLike}, '%')
            </if>
            <if test="methodLike != null and methodLike != ''">
                AND method LIKE CONCAT('%', #{methodLike}, '%')
            </if>
            <if test="ipLike != null and ipLike != ''">
                AND ip LIKE CONCAT('%', #{ipLike}, '%')
            </if>
            <if test="errorMsgLike != null and errorMsgLike != ''">
                AND error_msg LIKE CONCAT('%', #{errorMsgLike}, '%')
            </if>
            
            <!-- 时间范围查询 -->
            <if test="startTime != null">
                AND create_time >= #{startTime}
            </if>
            <if test="endTime != null">
                AND create_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>
    
    <!-- 插入 -->
    <insert id="insert" parameterType="com.tianhai.warn.model.SystemLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO system_log (
            log_id, user_no, username, user_role, operation, method, params, ip, status, error_msg, create_time
        ) VALUES (
            #{logId,jdbcType=VARCHAR}, #{userNo,jdbcType=VARCHAR}, #{username,jdbcType=VARCHAR}, 
            #{userRole,jdbcType=VARCHAR}, #{operation,jdbcType=VARCHAR}, #{method,jdbcType=VARCHAR}, 
            #{params,jdbcType=VARCHAR}, #{ip,jdbcType=VARCHAR}, #{status,jdbcType=VARCHAR}, 
            #{errorMsg,jdbcType=VARCHAR}, NOW()
        )
    </insert>
    
    <!-- 更新 -->
    <update id="update" parameterType="com.tianhai.warn.model.SystemLog">
        UPDATE system_log
        <set>
            <if test="userNo != null">user_no = #{userNo},</if>
            <if test="username != null">username = #{username},</if>
            <if test="userRole != null">user_role = #{userRole},</if>
            <if test="operation != null">operation = #{operation},</if>
            <if test="method != null">method = #{method},</if>
            <if test="params != null">params = #{params},</if>
            <if test="ip != null">ip = #{ip},</if>
            <if test="status != null">status = #{status},</if>
            <if test="errorMsg != null">error_msg = #{errorMsg},</if>
        </set>
        WHERE id = #{id}
    </update>
    
    <!-- 删除 -->
    <delete id="deleteById">
        DELETE FROM system_log WHERE id = #{id}
    </delete>
    
    <!-- 根据用户编号查询 -->
    <select id="selectByUserNo" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM system_log
        WHERE user_no = #{userNo}
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据用户名查询 -->
    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM system_log
        WHERE username = #{username}
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据用户角色查询 -->
    <select id="selectByUserRole" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM system_log
        WHERE user_role = #{userRole}
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据操作内容查询 -->
    <select id="selectByOperation" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM system_log
        WHERE operation LIKE CONCAT('%', #{operation}, '%')
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据状态查询 -->
    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM system_log
        WHERE status = #{status}
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据时间范围查询 -->
    <select id="selectByTimeRange" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM system_log
        WHERE create_time BETWEEN #{startTime} AND #{endTime}
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据logId查询 -->
    <select id="selectByLogId" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM system_log
        WHERE log_id = #{logId}
    </select>
    
    <!-- 批量删除 -->
    <delete id="batchDelete">
        DELETE FROM system_log
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <!-- 清空指定时间之前的日志 -->
    <delete id="deleteBeforeTime">
        DELETE FROM system_log
        WHERE create_time &lt; #{time}
    </delete>

    <!-- 更新学号 -->
    <update id="updateStudentNo">
        UPDATE system_log
        SET user_no = #{newStudentNo}
        WHERE user_no= #{oldStudentNo}
        AND (user_role = 'student' OR user_role = 'STUDENT')
    </update>
</mapper>