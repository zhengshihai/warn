<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tianhai.warn.mapper.SuperAdminMapper">

    <resultMap id="BaseResultMap" type="com.tianhai.warn.model.SuperAdmin">
        <id column="id" property="id" />
        <result column="name" property="name" />
        <result column="password" property="password" />
        <result column="email" property="email" />
        <result column="enabled" property="enabled" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="version" property="version"/>
        <result column="last_login_time" property="lastLoginTime"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM super_admin WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM super_admin ORDER BY id ASC
    </select>

    <insert id="insert" parameterType="com.tianhai.warn.model.SuperAdmin" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO super_admin (name, password, email, enabled, create_time, update_time, version, last_login_time)
        VALUES (#{name}, #{password}, #{email}, #{enabled}, NOW(), NOW(), 0, NOW())
    </insert>

<!--    <update id="update" parameterType="com.tianhai.warn.model.SuperAdmin">-->
