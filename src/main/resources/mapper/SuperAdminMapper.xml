<!--        SET name = #{name},-->
<!--            password = #{password},-->
<!--            email = #{email},-->
<!--            enabled = #{enabled},-->
<!--            update_time = NOW(),-->
<!--            version = version + 1-->
<!--        WHERE id = #{id} AND version = #{version}-->
<!--    </update>-->
    <update id="update" parameterType="com.tianhai.warn.model.SuperAdmin">
        UPDATE super_admin
        <set>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="password != null and password != ''">
                password = #{password},
            </if>
            <if test="email != null and email != ''">
                email = #{email},
            </if>
            <if test="enabled != null">
                enabled = #{enabled},
            </if>
            <if test ="lastLoginTime != null">
                last_login_time = #{lastLoginTime},
            </if>
            update_time = NOW(),
            version = version + 1
        </set>
        WHERE id = #{id} AND version = #{version}
    </update>


    <delete id="deleteById">
        DELETE FROM super_admin WHERE id = #{id}
    </delete>

    <select id="selectByCondition" parameterType="com.tianhai.warn.model.SuperAdmin" resultMap="BaseResultMap">
        SELECT * FROM super_admin
        <where>
            <if test="id != null">
                AND id = #{id}
            </if>
            <if test="name != null and name != ''">
                AND name = #{name}
            </if>
            <if test="email != null and email != ''">
                AND email = #{email}
            </if>
            <if test="enabled != null">
                AND enabled = #{enabled}
            </if>
            <if test="createTime != null">
                AND create_time = #{createTime}
            </if>
            <if test="updateTime != null">
                AND update_time = #{updateTime}
            </if>
            <if test="lastLoginTime != null">
                AND last_login_time = #{lastLoginTime}
            </if>
        </where>
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM super_admin
    </select>

    <update id="updateLastLoginTime">
        UPDATE super_admin
        SET last_login_time = NOW(),
            update_time = NOW(),
            version = version + 1
        WHERE id = #{id}
    </update>

    <insert id="insertBatch" parameterType="java.util.List">
    INSERT INTO super_admin
        (name, password, email, enabled, create_time, update_time, version)
    VALUES
    <foreach collection="superAdminList" item="item" separator=",">
        (
            #{item.name},
            #{item.password},
            #{item.email},
            #{item.enabled},
            #{item.createTime},
            #{item.updateTime},
            #{item.version}
        )
    </foreach>
</insert>
</mapper>
