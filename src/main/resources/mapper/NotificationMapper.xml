<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tianhai.warn.mapper.NotificationMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.tianhai.warn.model.Notification">
        <id column="id" property="id"/>
        <result column="notice_id" property="noticeId"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="notice_type" property="noticeType"/>
        <result column="target_type" property="targetType"/>
        <result column="target_id" property="targetId"/>
        <result column="target_scope" property="targetScope"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
<!--        <result column="es_indexed" property="esIndexed" jdbcType="INTEGER"/>-->
    </resultMap>
    
    <!-- 通用查询结果列（已移除 es_indexed 字段，简化业务不再使用ES） -->
    <sql id="Base_Column_List">
        id, notice_id, title, content, notice_type, target_type, target_id, target_scope, create_time, update_time
    </sql>
    
    <!-- 根据查询条件查询通知信息列表 -->
    <select id="selectByQuery" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM notification
        <where>
            <!-- 精确匹配：通知ID -->
            <if test="noticeId != null and noticeId != ''">
                AND notice_id = #{noticeId}
            </if>
            
            <!-- 精确匹配：通知类型 -->
            <if test="noticeType != null and noticeType != ''">
                AND notice_type = #{noticeType}
            </if>
            
            <!-- 精确匹配：通知目标角色类型 -->
            <if test="targetType != null and targetType != ''">
                AND target_type = #{targetType}
            </if>
            
            <!-- 精确匹配：通知目标ID -->
            <if test="targetId != null and targetId != ''">
                AND target_id = #{targetId}
            </if>
            
            <!-- 精确匹配：通知范围 -->
            <if test="targetScope != null and targetScope != ''">
                AND target_scope = #{targetScope}
            </if>

            <!-- 精确匹配：ES索引状态（已移除，简化业务不再使用ES） -->
            <!-- <if test="esIndexed != null">
                AND es_indexed = #{esIndexed}
            </if> -->
            
            <!-- 模糊查询：通知标题 -->
            <if test="titleLike != null and titleLike != ''">
                AND title LIKE CONCAT('%', #{titleLike}, '%')
            </if>
            
            <!-- 模糊查询：通知内容 -->
            <if test="contentLike != null and contentLike != ''">
                AND content LIKE CONCAT('%', #{contentLike}, '%')
            </if>
            
            <!-- 批量匹配：多个通知ID -->
            <if test="noticeIdList != null and noticeIdList.size() > 0">
                AND notice_id IN
                <foreach collection="noticeIdList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>

            <!-- 批量匹配： 多个通知目标ID -->
            <if test="targetIdList != null and targetIdList.size() > 0">
                AND target_id IN
                <foreach collection="targetIdList" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
            
            <!-- 创建时间范围查询 -->
            <if test="createTimeStart != null">
                AND create_time >= #{createTimeStart}
            </if>
            <if test="createTimeEnd != null">
                AND create_time &lt;= #{createTimeEnd}
            </if>
        </where>
        
        <!-- 排序 -->
        <choose>
            <when test="sortField != null and sortField != '' and sortOrder != null and sortOrder != ''">
                ORDER BY ${sortField} ${sortOrder}
            </when>
            <otherwise>
                ORDER BY create_time DESC
            </otherwise>
        </choose>
    
    </select>

    <!-- 学生端简化列表：target_id 命中 或 全体通知（与 TargetScope.ALL_USERS 的 code「allusers」及管理员发布的 ALL_USERS 兼容） -->
    <select id="selectSimplePageForTarget" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM notification n
        WHERE (
            n.target_id = #{targetId}
            OR n.target_scope = 'ALL_USERS'
            OR n.target_scope = 'allusers'
        )
        ORDER BY n.create_time DESC
    </select>

    <select id="selectAllNotificationMainInfo" resultType="com.tianhai.warn.model.Notification">
        SELECT notice_id, notice_type, title, content
        FROM notification
    </select>

    <select id="selectBatchWithOffset" resultType="com.tianhai.warn.model.Notification">
        SELECT * FROM notification
        ORDER BY id ASC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countAll" resultType="java.lang.Integer">
        SELECT count(*) FROM notification
    </select>

    <!-- 插入通知信息（已移除 es_indexed 字段） -->
    <insert id="insert" parameterType="com.tianhai.warn.model.Notification">
        INSERT INTO notification (
            notice_id,
            title,
            content,
            notice_type,
            target_type,
            target_id,
            target_scope,
            create_time,
            update_time
        ) VALUES (
            #{noticeId},
            #{title},
            #{content},
            #{noticeType},
            #{targetType},
            #{targetId},
            #{targetScope},
            #{createTime},
            #{updateTime}
        )
    </insert>

    <!-- 批量插入通知信息（已移除 es_indexed 字段） -->
    <insert id="insertBatch" parameterType="java.util.List">
        INSERT INTO notification (
        notice_id,
        title,
        content,
        notice_type,
        target_type,
        target_id,
        target_scope,
        create_time,
        update_time
        )
        VALUES
        <foreach collection="notificationList" item="item" separator=",">
            (
            #{item.noticeId},
            #{item.title},
            #{item.content},
            #{item.noticeType},
            #{item.targetType},
            #{item.targetId},
            #{item.targetScope},
            #{item.createTime},
            #{item.updateTime}
            )
        </foreach>
    </insert>

    <delete id="deleteBatch" parameterType="com.tianhai.warn.query.NotificationQuery">
        DELETE FROM notification
        <where>
            <if test="noticeId != null and noticeId != ''">
                AND notice_id = #{noticeId}
            </if>
            <if test="noticeIdList != null and noticeIdList.size() > 0">
                AND notice_id IN
                <foreach collection="noticeIdList" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
            <if test="targetId != null and targetId != ''">
                AND target_id = #{targetId}
            </if>
            <if test="targetIdList != null and targetIdList.size() > 0">
                AND target_id IN
                <foreach collection="targetIdList" item="tid" open="(" separator="," close=")">
                    #{tid}
                </foreach>
            </if>
            <if test="targetType != null and targetType != ''">
                AND target_type = #{targetType}
            </if>
            <if test="targetScope != null and targetScope != ''">
                AND target_scope = #{targetScope}
            </if>
            <if test="noticeType != null and noticeType != ''">
                AND notice_type = #{noticeType}
            </if>
            <if test="createTimeStart != null">
                AND create_time &gt;= #{createTimeStart}
            </if>
            <if test="createTimeEnd != null">
                AND create_time &lt;= #{createTimeEnd}
            </if>
            <!-- ES索引状态条件已移除（简化业务不再使用ES） -->
            <!-- <if test="esIndexed != null">
                AND es_indexed = #{esIndexed}
            </if> -->
        </where>
    </delete>

     <!-- 更新语句（已移除 es_indexed 字段） -->
    <update id="update" parameterType="com.tianhai.warn.model.Notification">
        UPDATE notification 
        SET title = #{title},
            content = #{content},
            notice_type = #{noticeType},
            target_type = #{targetType},
            target_id = #{targetId},
            target_scope = #{targetScope},
            update_time = #{updateTime}
        WHERE notice_id = #{noticeId}
    </update>

      <!-- 更新ES索引状态（已注释，简化业务不再使用ES） -->
    <!-- <update id="updateEsIndexed">
        UPDATE notification 
        SET es_indexed = #{esIndexed},
            update_time = NOW()
        WHERE notice_id = #{noticeId}
    </update> -->

      <!-- 批量更新ES索引状态（已注释，简化业务不再使用ES） -->
    <!-- <update id="updateBatchEsIndexed">
        UPDATE notification 
        SET es_indexed = #{esIndexed},
            update_time = NOW()
        WHERE notice_id IN
        <foreach collection="noticeIdList" item="noticeId" open="(" separator="," close=")">
            #{noticeId}
        </foreach>
    </update> -->

      <!-- 查询未索引的通知（已注释，简化业务不再使用ES） -->
    <select id="selectUnindexedNotifications" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM notification 
        <!-- WHERE es_indexed = 0 OR es_indexed IS NULL -->
        WHERE 1 = 0
        ORDER BY create_time DESC
    </select>

       <!-- 分批次查询未索引的通知（已注释，简化业务不再使用ES） -->
    <select id="selectBatchUnindexed" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM notification 
        <!-- WHERE es_indexed = 0 OR es_indexed IS NULL -->
        WHERE 1 = 0
        ORDER BY create_time DESC
        LIMIT #{batchSize}
    </select>

    <!-- 统计未索引的通知数量（已注释，简化业务不再使用ES） -->
    <select id="countUnindexedNotifications" resultType="int">
        SELECT COUNT(*)
        FROM notification 
        <!-- WHERE es_indexed = 0 OR es_indexed IS NULL -->
        WHERE 1 = 0
    </select>

    <!-- 查询已索引的通知（已注释，简化业务不再使用ES） -->
    <select id="selectIndexedNotifications" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM notification 
        <!-- WHERE es_indexed = 1 -->
        WHERE 1 = 0
        ORDER BY create_time DESC
    </select>

</mapper> 