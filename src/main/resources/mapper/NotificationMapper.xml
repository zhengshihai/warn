<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tianhai.warn.mapper.NotificationMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.tianhai.warn.model.Notification">
        <id column="id" property="id"/>
        <result column="notice_id" property="noticeId"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="notice_type" property="noticeType"/>
        <result column="target_type" property="targetType"/>
        <result column="target_id" property="targetId"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
    
    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, notice_id, title, content, notice_type, target_type, target_id, status,
        create_time, update_time
    </sql>
    
    <!-- 根据ID查询 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM notification
        WHERE id = #{id}
    </select>
    
    <!-- 查询所有 -->
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM notification
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据条件查询 -->
    <select id="selectByCondition" resultMap="BaseResultMap" parameterType="com.tianhai.warn.query.NotificationQuery">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM notification
        <where>
            <!-- 单条件查询 -->
            <if test="title != null and title != ''">
                AND title LIKE CONCAT('%', #{title}, '%')
            </if>
            <if test="noticeType != null and noticeType != ''">
                AND notice_type = #{noticeType}
            </if>
            <if test="targetType != null and targetType != ''">
                AND target_type = #{targetType}
            </if>
            <if test="targetId != null and targetId != ''">
                AND target_id = #{targetId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="startNoticeTime != null">
                AND create_time &gt;= #{startNoticeTime}
            </if>
            <if test="endNoticeTime != null">
                AND create_time &lt;= #{endNoticeTime}
            </if>

            <!-- 批量查询条件 -->
            <if test="noticeIds != null and noticeIds.size() > 0">
                AND notice_id IN
                <foreach collection="noticeIds" item="noticeId" open="(" separator="," close=")">
                    #{noticeId}
                </foreach>
            </if>

            <if test="noticeTypes != null and noticeTypes.size() > 0">
                AND notice_type IN
                <foreach collection="noticeTypes" item="noticeType" open="(" separator="," close=")">
                    #{noticeType}
                </foreach>
            </if>

            <if test="targetIds != null and targetIds.size() > 0">
                AND target_id IN
                <foreach collection="targetIds" item="targetId" open="(" separator="," close=")">
                    #{targetId}
                </foreach>
            </if>
        </where>
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据目标类型和目标ID查询 -->
    <select id="selectByTarget" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM notification
        WHERE (target_type = #{targetType} AND target_id = #{targetId})
           OR target_type = 'ALL'
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据通知类型查询 -->
    <select id="selectByType" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM notification
        WHERE notice_type = #{noticeType}
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据状态查询 -->
    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT 
        <include refid="Base_Column_List"/>
        FROM notification
        WHERE status = #{status}
        ORDER BY create_time DESC
    </select>
    
    <!-- 根据noticeId查询 -->
    <select id="selectByNoticeId" resultMap="BaseResultMap">
        SELECT * FROM notification WHERE notice_id = #{noticeId}
    </select>
    
    <!-- 插入 -->
    <insert id="insert" parameterType="com.tianhai.warn.model.Notification" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO notification (
            notice_id, title, content, notice_type, target_type, target_id, status,
            create_time, update_time
        ) VALUES (
            #{noticeId}, #{title}, #{content}, #{noticeType}, #{targetType}, #{targetId}, #{status},
            NOW(), NOW()
        )
    </insert>
    
    <!-- 更新 -->
    <update id="update" parameterType="com.tianhai.warn.model.Notification">
        UPDATE notification
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="noticeType != null">notice_type = #{noticeType},</if>
            <if test="targetType != null">target_type = #{targetType},</if>
            <if test="targetId != null">target_id = #{targetId},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>
    
    <!-- 删除 -->
    <delete id="deleteById">
        DELETE FROM notification WHERE id = #{id}
    </delete>
    
    <!-- 更新状态 -->
    <update id="updateStatus">
        UPDATE notification
        SET status = #{status},
            update_time = NOW()
        WHERE notice_id = #{noticeId}
    </update>
    
    <!-- 批量更新状态 -->
    <update id="batchUpdateStatus">
        UPDATE notification
        SET status = #{status},
            update_time = NOW()
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <!-- 批量更新 -->
    <update id="updateBatch">
        <foreach collection="notificationList" item="item" separator=";">
            UPDATE notification
            <set>
                <if test="item.title != null">title = #{item.title},</if>
                <if test="item.content != null">content = #{item.content},</if>
                <if test="item.noticeType != null">type = #{item.noticeType},</if>
                <if test="item.targetType != null">target_type = #{item.targetType},</if>
                <if test="item.targetId != null">target_id = #{item.targetId},</if>
                <if test="item.status != null">status = #{item.status},</if>
                <if test="item.createTime != null">create_time = #{item.createTime},</if>
                <if test="item.updateTime != null">update_time = #{item.updateTime},</if>
            </set>
            WHERE id = #{item.id}
        </foreach>
    </update>
</mapper> 